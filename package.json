{
  "name": "pcd-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static web app to convert Kodak Photo CD (PCD) files to color-managed JPEG or TIFF, entirely in the browser via WebAssembly.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:wasm": "node scripts/build-wasm.mjs",
    "test:wasm": "node scripts/test-wasm.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.3"
  }
}
